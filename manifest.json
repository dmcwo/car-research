{
  "manifest_version": 3,
  "name": "Car Research",
  "version": "1.0.0",
  "description": "Extract, review, and export car listing data for comparison shopping.",
  "browser_specific_settings": {
    "gecko": {
      "id": "car-research@dmcwo",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "sidebar_action": {
    "default_panel": "sidebar/sidebar.html",
    "default_icon": { "48": "icons/icon-48.png" },
    "default_title": "Car Research"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Car Research — click to toggle sidebar"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
